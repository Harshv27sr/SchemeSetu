# ==========================================
# SchemeSetu Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values

# MongoDB Atlas Connection String (Get from atlas.mongodb.com)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/schemesetu?retryWrites=true&w=majority

# JWT Secret Key (any long random string, keep it secret!)
JWT_SECRET=schemesetu_super_secret_jwt_key_change_this_in_production

# Server Port (Render will auto-set this)
PORT=5000

# Node Environment
NODE_ENV=production

# Frontend URL (update after deploying frontend on Vercel)
FRONTEND_URL=https://your-app-name.vercel.app
